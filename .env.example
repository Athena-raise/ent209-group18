# Frontend
# Leave empty on Vercel to use the same-origin /api routes.
VITE_API_BASE_URL=
# Set to true only when you want placeholder exercise data without media.
VITE_USE_MOCK_EXERCISES=false

# Local dev only: Vite proxy target for npm run dev
VITE_API_PROXY_TARGET=http://localhost:3000

# Auth / app
APP_BASE_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
ENABLE_EMAIL_VERIFICATION=false

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI nutrition estimation
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Boohee food data API
# Keep app key on the server only. Photo recognition needs BOOHEE_IMAGE_BASE_URL
# or APP_BASE_URL to be reachable by Boohee's servers.
BOOHEE_APP_ID=
BOOHEE_APP_KEY=
BOOHEE_APP_USER_ID=synergyx-server
BOOHEE_API_BASE_URL=https://fc.boohee.com
BOOHEE_IMAGE_API_BASE_URL=https://api.boohee.com
BOOHEE_IMAGE_BASE_URL=
BOOHEE_IMAGE_STORAGE_BUCKET=boohee-food-images
BOOHEE_RECOGNITION_POLL_ATTEMPTS=8
BOOHEE_RECOGNITION_POLL_DELAY_MS=1200

# MuscleWiki API
MUSCLEWIKI_API_BASE_URL=https://api.musclewiki.com
MUSCLEWIKI_API_KEY=
# Set to true to disable MuscleWiki requests.
MUSCLEWIKI_API_DISABLED=false

# Preferred email setup for Vercel: Resend
RESEND_API_KEY=
EMAIL_FROM=Health Tracker <no-reply@example.com>
EMAIL_REPLY_TO=

# SMTP fallback
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
